{
    kernel::declare_non_priv_process_storage!(PROCESS_STORAGE);
    const PROCESS_ID: *const () =
        kernel::non_priv_process_id!(PROCESS_STORAGE);

    let mut process = unsafe { kernel::declare_non_priv_process!(
        PROCESS_STORAGE,
        "{{app.process.name}}",
        MEMORY_CONFIG_{{app.name | upper}},
        object_table_{{app.name}}
    )};
    process.object = Some(object_{{app.name}}_process.clone());

    // TODO: https://pwbug.dev/496950345 - Merge with object declaration.
    {% for thread in app.process.threads %}
        {% include "thread_decl" %}
    {% endfor %}

    // TODO: https://pwbug.dev/496970887 - Don't assume thread 0 is main.
    let main_thread_object =
        object_{{app.name}}_{{app.process.threads[0].name | to_lower_ident}}
        .clone();
    let main_thread = Some(kernel::object::MainThread {
        thread: main_thread_object,
        initial_pc: start_fn_{{app.name}},
        initial_sp: {{app.initial_sp | hex}},
    });

    if let Err(_e) = object_{{app.name}}_process.set_process(
        arch::Arch,
        process,
        main_thread
    ) {
        kernel::macro_exports::pw_assert::panic!("Failed to set process object");
    }
}
