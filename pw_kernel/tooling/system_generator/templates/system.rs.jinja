#![no_std]
#![allow(unused_imports)]
#![expect(clippy::redundant_closure_call)]

{% if kernel.interrupt_table %}
{%- include "interrupts" -%}
{% endif %}

{% if userspace %}
{% if apps | length > 0 %}
pub fn start() {
    use core::ptr::NonNull;
    use foreign_box::{ForeignBox, ForeignRc, static_foreign_box, static_foreign_rc, upcast_foreign_rc};
    use kernel::object::{KernelObject, ObjectTable};
    use {{ arch_crate_name }} as arch;
    use arch::MemoryConfig;
    use kernel::__private::kernel_config::KernelConfigInterface;

    type K = arch::Arch;
    #[allow(unused_variables)]
    let kernel = arch::Arch;

    // Declare all main process objects first so that other apps can reference them.
    {%- for app in apps %}
    let object_{{app.name}}_process =
        {% include "object_process" %};
    {%- endfor %}

    // Channel handlers are declared first so that initiators can reference them.
    // Unlike other object templates, handlers return a tuple of two ForeignRcs.
    // The first is a `dyn KernelObject<K>` which is suitable for adding to a
    // processes object table.  The second is a `ChannelHandlerObject<K>` which
    // is suitable for creating a `ChannelInitiator` object
    {%- for app in apps %}
    {%- for object in app.process.objects %}
        {% if object.type == "channel_handler" -%}
            let object_{{app.name}}_{{object.name | to_lower_ident}} =
                {% include "object_channel_handler" %};
            #[allow(unused_variables)]
            let object_{{app.name}}_{{object.name | to_lower_ident}}_handler =
                object_{{app.name}}_{{object.name | to_lower_ident}}.clone();

        {%- endif -%}
        // Other objects declared later.
    {%- endfor -%}
    {%- endfor -%}

    {%- for app in apps %}
    let start_fn_{{app.name}} = {{app.start_fn_address | hex}}_usize;

    const MEMORY_CONFIG_{{app.name | to_upper_ident }}: MemoryConfig = MemoryConfig::const_new(&[
        {%- for mapping in app.process.memory_mappings %}
        memory_config::MemoryRegion::new(
            {% if mapping.type == "device" -%}
            memory_config::MemoryRegionType::Device,
            {% elif mapping.type == "read_only_executable" -%}
            memory_config::MemoryRegionType::ReadOnlyExecutable,
            {% elif mapping.type == "read_write_data" -%}
            memory_config::MemoryRegionType::ReadWriteData,
            {% endif -%}
            {{mapping.start_address | hex}},
            {{(mapping.start_address + mapping.size_bytes) | hex}},
        ),
        {%- endfor -%}
    ]);

    {%- for object in app.process.objects %}
        let object_{{app.name}}_{{object.name | to_lower_ident }} =
        {% if object.type == "channel_handler" -%}
                // Reference to handler object already declared above.
                object_{{app.name}}_{{object.name | to_lower_ident}}
        {% elif object.type == "channel_initiator" -%}
            {% include "object_channel_initiator" %}
        {% elif object.type == "interrupt" -%}
            {% include "object_interrupt" %}
        {%- elif object.type == "process" %}
            object_{{object.linked_process}}_process.clone()
        {%- elif object.type == "thread" %}
            {% include "object_thread" %}
        {% elif object.type == "wait_group" -%}
            {% include "object_wait_group" %}
        {%- endif -%}
        ;
    {%- endfor %}

    let object_table_{{app.name}}: ForeignBox<dyn ObjectTable<K>> = unsafe {
        static_foreign_box!(
            [ForeignRc<<K as kernel::Arch>::AtomicUsize, dyn KernelObject<K>>; {{app.process.objects | length}}],
            [
                {%- for object in app.process.objects %}
                    upcast_foreign_rc!(
                        object_{{app.name}}_{{object.name | to_lower_ident}}.clone()
                        => dyn KernelObject<K>
                    ),
                {%- endfor %}
            ]
        )
    };

    {# Declare storage for and initialize processes and their threads.  This
       binds the declared processes and threads to the process and thread
       objects declared above. #}
    {% include "process_decl" %}

    if let Err(e) = object_{{app.name | to_lower_ident }}_process.start(arch::Arch) {
        kernel::macro_exports::pw_assert::panic!(
            "Error starting process: {{app.process.name}}: {}",
            e as i32
        );
    }
{%- endfor %}
}
{%- endif %}
{% endif %}
